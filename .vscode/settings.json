{
  "search.exclude": {
    "**/node_modules": true,
    "**/*.code-search": true,
    "**/public":true
  },
  "files.eol": "\n",
  "editor.inlayHints.enabled": "on",
  "editor.inlayHints.padding": true,
  "editor.foldingImportsByDefault": true,
  "js/ts.suggest.autoImports": true,
  "js/ts.suggest.completeFunctionCalls": true,
  "js/ts.suggest.enabled": true,
  "js/ts.suggest.jsdoc.generateReturns": true,
  "js/ts.suggest.paths": true,
  "js/ts.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyParenthesis": false,
  "js/ts.format.insertSpaceAfterFunctionKeywordForAnonymousFunctions": true,
  "js/ts.format.insertSpaceAfterKeywordsInControlFlowStatements": true,
  "js/ts.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBrackets": true,
  "js/ts.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true,
  "js/ts.format.insertSpaceAfterOpeningAndBeforeClosingEmptyBraces": false,
  "js/ts.format.insertSpaceAfterOpeningAndBeforeClosingJsxExpressionBraces": false,
  "js/ts.format.insertSpaceAfterCommaDelimiter": true,
  "js/ts.format.insertSpaceAfterSemicolonInForStatements": true,
  "js/ts.format.insertSpaceAfterOpeningAndBeforeClosingTemplateStringBraces": true,
  "js/ts.format.indentSwitchCase": true,
  "js/ts.preferences.importModuleSpecifier": "shortest",
  "js/ts.preferences.importModuleSpecifierEnding": "js",
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": false,
  "js/ts.inlayHints.parameterNames.enabled": "all",
  "js/ts.inlayHints.parameterNames.suppressWhenArgumentMatchesName": true,
  "js/ts.inlayHints.parameterTypes.enabled": false,
  "js/ts.inlayHints.propertyDeclarationTypes.enabled": false,
  "js/ts.inlayHints.variableTypes.enabled": false,
  "js/ts.inlayHints.variableTypes.suppressWhenTypeMatchesName": true,
  "js/ts.inlayHints.enumMemberValues.enabled": false,
  "js/ts.format.insertSpaceAfterTypeAssertion": true,
  "json.schemas": [
    {
      "fileMatch": [
        "**/*.fiveserverrc"
      ],
      "url": "/.vscode/fiveserver.schema.json"
    }
  ],
  "cSpell.words": [
    "Arduino",
    "crosshair",
    "Espruino",
    "grayscale",
    "importmap",
    "ixfx",
    "WLED"
  ],
  "chat.agent.enabled": false,
  "chat.commandCenter.enabled": false,
  "chat.extensionTools.enabled": false,
  "chat.sendElementsToChat.enabled": false,
  "livePreview.showServerStatusNotifications": false,
  "livePreview.serverRoot": "./public",
  "workbench.activityBar.location": "top",
  "workbench.sideBar.location": "right",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "terminal.integrated.fontLigatures.enabled": true,
  "editor.insertSpaces": true,
  "editor.tabSize": 2,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 5,
  "chat.mcp.access": "none",
  // Disable the default formatter, use eslint instead.
  "prettier.enable": false,
  "editor.formatOnSave": false,
  // Auto fix
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "never"
  },
  // Silent the stylistic rules in your IDE, but still auto fix them
  "eslint.rules.customizations": [
    {
      "rule": "style/*",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "format/*",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*-indent",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*-spacing",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*-spaces",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*-order",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*-dangle",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*-newline",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*quotes",
      "severity": "off",
      "fixable": true
    },
    {
      "rule": "*semi",
      "severity": "off",
      "fixable": true
    }
  ],
  // Enable eslint for all supported languages
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue",
    "html",
    "markdown",
    "json",
    "jsonc",
    "yaml",
    "toml",
    "xml",
    "gql",
    "graphql",
    "astro",
    "svelte",
    "css",
    "less",
    "scss",
    "pcss",
    "postcss"
  ],
}